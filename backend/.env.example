# Database
DATABASE_URL="file:./prisma/dev.db"

# Server
PORT=3000
FRONTEND_URL=http://localhost:8000

# Admin
ADMIN_PASSWORD=admin123

# Email (Resend) — optional. If unset, emails are logged to console.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Templo Bahá'í de Sudamérica <onboarding@resend.dev>
EMAIL_REPLY_TO=visitas@bahai.cl

# Comma-separated emails that get a notification on every new reservation.
STAFF_NOTIFICATION_EMAILS=visitas@bahai.cl,monajulietm@gmail.com

# Google Sheets logging — optional. If unset, logging is skipped.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB="Registro de Grupos"
GOOGLE_FERIADOS_TAB="Feriados"

# Google Calendar — optional. If unset, no calendar events are created.
GOOGLE_CALENDAR_ID=
CALENDAR_INVITE_EMAIL=monajulietm@gmail.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# IMPORTANT: keep the surrounding double-quotes; \n's stay as the literal two chars
GOOGLE_PRIVATE_KEY=""

# Cloudflare Turnstile — optional. If unset, CAPTCHA is bypassed.
CAPTCHA_SECRET_KEY=
