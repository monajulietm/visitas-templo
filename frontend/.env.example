# Local development: leave VITE_BACKEND_URL empty (Vite proxies /api to localhost:3000).
# Production build: set this to your deployed backend URL, e.g.
#   VITE_BACKEND_URL=https://templo-backend.up.railway.app
VITE_BACKEND_URL=

# Optional Cloudflare Turnstile site key. If set, CAPTCHA renders on the form.
VITE_CAPTCHA_SITE_KEY=
